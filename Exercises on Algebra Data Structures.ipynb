      "source": [
        "# Misalkan nilai s (contoh: s = 1)\n",
        "s = 1\n",
        "\n",
        "# Buat vector (kolom)\n",
        "v = np.array([[2*s],\n",
        "              [2],\n",
        "              [-3],\n",
        "              [-2*s]])\n",
        "\n",
        "print(\"Vector awal:\")\n",
        "print(v)\n",
        "\n",
        "# Transpose vector\n",
        "v_T = v.T\n",
        "\n",
        "print(\"\\nTranspose vector:\")\n",
        "print(v_T)"
      ]
    }
